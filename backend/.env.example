# ─── Server ──────────────────────────────────────────────────────────────────
NODE_ENV=development
PORT=4000
# Comma-separated list of allowed CORS origins (the frontend URL)
CORS_ORIGINS=http://localhost:5173,http://localhost:3000

# ─── Database (PostgreSQL) ─────────────────────────────────────────────────────
# Either provide a full connection string...
DATABASE_URL=postgresql://eprx:eprx_password@localhost:5432/eprescription
# ...or individual parts (DATABASE_URL takes precedence when set)
PGHOST=localhost
PGPORT=5432
PGUSER=eprx
PGPASSWORD=eprx_password
PGDATABASE=eprescription
# Set to "true" when connecting to a managed DB that requires SSL
PGSSL=false
# Max connections per pool. Keep small (e.g. 1-5) on serverless platforms like
# Vercel where each function instance has its own pool; use a connection pooler.
DB_POOL_MAX=20

# ─── Authentication / JWT ──────────────────────────────────────────────────────
# Generate with: node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
JWT_ACCESS_SECRET=change_me_access_secret_minimum_32_chars_long
JWT_REFRESH_SECRET=change_me_refresh_secret_minimum_32_chars_long
JWT_ACCESS_TTL=15m
JWT_REFRESH_TTL=7d
# Secret used to sign email verification & password reset tokens
EMAIL_TOKEN_SECRET=change_me_email_token_secret_minimum_32_chars

# ─── Email (SMTP) ──────────────────────────────────────────────────────────────
# For local dev, leave EMAIL_TRANSPORT=stream to print emails to the console.
# For production set EMAIL_TRANSPORT=smtp and fill in the SMTP_* values.
EMAIL_TRANSPORT=stream
EMAIL_FROM="ePrescribe <no-reply@eprescribe.local>"
SMTP_HOST=smtp.mailtrap.io
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
# Base URL the verification/reset links point at (the frontend)
APP_PUBLIC_URL=http://localhost:5173
# Set to "true" to mark new registrations verified immediately (no verification
# email needed). Convenient for setup/environments without SMTP. Keep "false"
# in production.
AUTO_VERIFY_EMAIL=false

# ─── External services ─────────────────────────────────────────────────────────
# RxNorm (NIH/NLM) is a free, public, no-auth API used for medication lookup.
RXNORM_BASE_URL=https://rxnav.nlm.nih.gov/REST

# Pharmacy network adapter: "internal" (built-in simulated routing) or "surescripts".
# Surescripts requires certified credentials obtained after onboarding/certification.
PHARMACY_NETWORK=internal
SURESCRIPTS_BASE_URL=
SURESCRIPTS_ACCOUNT_ID=
SURESCRIPTS_API_KEY=
