# Base URL of the backend API. The hosting platform mounts the backend under
# the "/_/backend" route prefix (see app.json), and the Vite dev proxy forwards
# it to the backend, so the default works in dev and prod. Override only if you
# host the API on a separate origin, e.g. https://api.yourpractice.com/api
VITE_API_BASE_URL=/_/backend/api

# Used only by the dev server proxy target
VITE_API_PROXY=http://localhost:4000
